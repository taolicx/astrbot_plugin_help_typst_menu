{
  "enable_waiting_message": {
    "description": "启用等待提示",
    "type": "bool",
    "default": false,
    "hint": "开启后，查询菜单时会先发送一条提示，并在结果生成后撤回"
  },
  "ignored_plugins": {
    "description": "黑名单插件 ID",
    "type": "list",
    "default": [
      "astrbot",
      "astrbot-web-searcher",
      "astrbot-python-interpreter",
      "session_controller",
      "builtin_commands",
      "astrbot-reminder",
      "astrbot_plugin_help_typst",
      "astrbot_plugin_text_menu"
    ],
    "hint": "屏蔽不想展示的插件菜单，填写 metadata.yaml 的 name 字段"
  }
}
