{
  "enable_waiting_message": {
    "description": "启用等待提示",
    "type": "bool",
    "default": false,
    "hint": "开启后，生成图片时会发送'正在搜索/渲染...'，并在完成后撤回"
  },
  "ignored_plugins": {
    "description": "黑名单插件 ID",
    "type": "list",
    "default": [
      "astrbot", 
      "astrbot-web-searcher", 
      "astrbot-python-interpreter",
      "session_controller",
      "builtin_commands",
      "astrbot-reminder", 
      "astrbot_plugin_help_typst"
    ],
    "hint": "屏蔽不想展示、导致问题的插件菜单 (使用 name 字段)"
  },
  "custom_font_path": {
    "description": "自定义字体目录",
    "type": "string",
    "default": "",
    "hint": "绝对路径。缺省值 .../data/plugin_data/astrbot_plugin_help_typst/fonts"
  },
  "rendering": {
    "description": "渲染引擎设置",
    "type": "object",
    "items": {
      "timeout_analysis": {
        "description": "数据分析超时 (秒)",
        "type": "float",
		"slider": {
          "min": 3,
          "max": 30,
          "step": 1
        },
        "default": 10.0,
        "hint": "生成数据结构的超时时间，根据插件数量调整"
      },
      "timeout_compile": {
        "description": "Typst 编译超时 (秒)",
        "type": "float",
		"slider": {
          "min": 3,
          "max": 60,
          "step": 1
        },
        "default": 30.0,
        "hint": "调用 Typst 编译图片的超时时间，根据其他项目调整"
      },
	  "max_concurrent_tasks": {
        "description": "最大并发编译数",
        "type": "int",
		"slider": {
          "min": 1,
          "max": 10,
          "step": 1
        },
        "default": 2,
        "hint": "同时进行的 Typst 编译任务数量限制，根据 CPU 调整"
      },
	  "ppi": {
        "description": "图片清晰度 (PPI)",
        "type": "float",
		"slider": {
          "min": 64,
          "max": 256,
          "step": 1
        },
        "default": 180.0,
        "hint": "越高图片越清晰，但越慢&大&高占用，根据内存 & 带宽调整"
      },
      "giant_threshold": {
        "description": "巨型块阈值 (pt)",
        "type": "int",
		"slider": {
          "min": 100,
          "max": 3000,
          "step": 100
        },
        "default": 1500,
        "hint": "超过此高度的插件将独占一行显示 (仅 Event/Filter 模式有效)"
      },
	  "split_height": {
        "description": "长图切分高度 (px)",
        "type": "int",
		"slider": {
          "min": 1000,
          "max": 16000,
          "step": 1000
        },
        "default": 16000,
        "hint": "当图片高度超过 WebP 限制时的切分单位高度"
      }
    }
  },
  "appearance": {
    "description": "外观与主题预设",
    "type": "object",
    "items": {
      "active_preset": {
        "description": "当前激活的预设名称",
        "type": "string",
        "default": "default",
        "hint": "填写下方预设列表中的 '预设名称' (preset_name)"
      },
      "presets": {
        "description": "主题预设列表",
        "type": "template_list",
        "default": [
          {
            "__template_key": "standard_theme",
            "preset_name": "default",
            "font_order": ["Sarasa Gothic SC", "Noto Color Emoji"]
          }
        ],
        "templates": {
          "standard_theme": {
            "name": "标准主题模板",
            "hint": "自定义字体优先级",
            "items": {
              "preset_name": {
                "description": "预设名称 (ID)",
                "type": "string",
                "default": "custom_1",
                "hint": "用于在上方 'active_preset' 中引用"
              },
              "font_order": {
                "description": "字体优先级排序",
                "type": "list",
                "hint": "勾选启用字体，调整回退顺序 (排在前面的优先使用)",
                "default": ["Sarasa Gothic SC", "Noto Color Emoji"],
                "options": ["Sarasa Gothic SC", "Noto Color Emoji"]
              }
            }
          }
        }
      }
    }
  }
}